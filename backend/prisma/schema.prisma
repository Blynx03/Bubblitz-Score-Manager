generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int        @id @default(autoincrement())
  name      String
  status    PlayStatus @default(NEW)
  createdAt DateTime   @default(now())
  email     String     @unique
  scores    Scores[]
}

model Scores {
  id        Int      @id @default(autoincrement())
  userId    Int
  value     Int
  level     Int
  time      Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

enum PlayStatus {
  NEW
  ACTIVE
}

enum Role {
  ADMIN
  GUEST
}

model AdminUser {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(GUEST)
  isProtected Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}